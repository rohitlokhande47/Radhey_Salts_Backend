  "item": [
    {
      "name": "Health & Monitoring",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["if (pm.response.code === 200) {", "  var jsonData = pm.response.json();", "  pm.environment.set(\"adminToken\", jsonData.data.accessToken);", "  pm.environment.set(\"adminId\", jsonData.data.admin._id);", "}"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@radhey.com\", \"password\": \"Admin@123\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/admin/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "admin", "login"]
            }
          }
        },
        {
          "name": "Dealer Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["if (pm.response.code === 200) {", "  var jsonData = pm.response.json();", "  pm.environment.set(\"dealerToken\", jsonData.data.accessToken);", "  pm.environment.set(\"dealerId\", jsonData.data.dealer._id);", "}"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"amit.patel@dealer.com\", \"password\": \"Dealer@123\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/dealer/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "dealer", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
